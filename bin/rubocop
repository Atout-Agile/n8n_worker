#!/usr/bin/env ruby
require "rubygems"
require "bundler/setup"

# explicit rubocop config increases performance slightly while avoiding config confusion.
# --force-exclusion ensures AllCops/Exclude patterns apply even when files are passed explicitly.
ARGV.unshift("--config", File.expand_path("../.rubocop.yml", __dir__), "--force-exclusion")

load Gem.bin_path("rubocop", "rubocop")
