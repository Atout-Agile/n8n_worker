<% content_for :title, "Dashboard — N8N Worker" %>

<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
  <p class="text-sm text-gray-500 mt-1">Welcome back, <%= current_user.name %>.</p>
</div>

<!-- User card -->
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 max-w-md">
  <div class="flex items-center gap-4 mb-6">
    <div class="w-12 h-12 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-lg">
      <%= current_user.name.first.upcase %>
    </div>
    <div>
      <p class="font-semibold text-gray-900"><%= current_user.name %></p>
      <p class="text-sm text-gray-500"><%= current_user.email %></p>
    </div>
  </div>

  <dl class="space-y-3 text-sm border-t border-gray-100 pt-4">
    <div class="flex justify-between">
      <dt class="text-gray-500">Role</dt>
      <dd>
        <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700">
          <%= current_user.role.name %>
        </span>
      </dd>
    </div>
  </dl>

  <div class="mt-6 pt-4 border-t border-gray-100">
    <%= link_to "Manage API Tokens →", api_v1_tokens_create_path,
          class: "text-sm font-medium text-indigo-600 hover:text-indigo-500 transition-colors" %>
  </div>
</div>
