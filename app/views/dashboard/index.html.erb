<div class="dashboard-container">
  <h1>Dashboard</h1>
  
  <% if current_user %>
    <p>Welcome, <%= current_user.name %>!</p>
    <p>Your email: <%= current_user.email %></p>
    <p>Your role: <%= current_user.role.name %></p>
    
    <%= button_to "Log out", logout_path, method: :delete, class: "btn btn-danger" %>
  <% end %>
</div> 