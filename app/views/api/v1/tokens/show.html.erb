<%#
API Token Details View
Displays information about a specific API token.
Used by Api::V1::TokensController#show action.

@param token [ApiToken] The token to display
%>
<% content_for :title, "#{@token.name} — API Token" %>

<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Token Details</h1>
    <p class="text-sm text-gray-500 mt-1"><%= @token.name %></p>
  </div>
  <%= link_to "← API Tokens", api_v1_tokens_path, class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" %>
</div>

<div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 max-w-md">
  <div class="flex items-center gap-3 mb-6">
    <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center">
      <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
      </svg>
    </div>
    <div>
      <p class="font-semibold text-gray-900"><%= @token.name %></p>
      <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
        <%= @token.active? ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700' %>">
        <%= @token.active? ? 'Active' : 'Expired' %>
      </span>
    </div>
  </div>

  <dl class="space-y-3 text-sm border-t border-gray-100 pt-4">
    <div class="flex justify-between">
      <dt class="text-gray-500">Token ID</dt>
      <dd class="font-mono text-gray-900 text-xs">#<%= @token.id %></dd>
    </div>
    <div class="flex justify-between">
      <dt class="text-gray-500">Created</dt>
      <dd class="text-gray-900"><%= @token.created_at.strftime("%b %d, %Y") %></dd>
    </div>
    <div class="flex justify-between">
      <dt class="text-gray-500">Expires</dt>
      <dd class="text-gray-900"><%= @token.expires_at.strftime("%b %d, %Y") %></dd>
    </div>
    <div class="flex justify-between">
      <dt class="text-gray-500">Last used</dt>
      <dd class="text-gray-900">
        <%= @token.last_used_at ? @token.last_used_at.strftime("%b %d, %Y at %I:%M %p") : "Never" %>
      </dd>
    </div>
  </dl>

  <% if flash[:raw_token] %>
    <div class="mt-6 pt-4 border-t border-gray-100">
      <p class="text-xs font-medium text-amber-800 mb-2">
        Copy this token now — it won't be shown again.
      </p>
      <code class="block text-xs font-mono break-all text-amber-900 bg-amber-100 rounded px-3 py-2">
        <%= flash[:raw_token] %>
      </code>
    </div>
  <% else %>
    <p class="mt-6 pt-4 border-t border-gray-100 text-xs text-gray-400">
      The token value is only shown once during creation for security purposes.
    </p>
  <% end %>
</div>
