<% content_for :title, "API Tokens — N8N Worker" %>

<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">API Tokens</h1>
    <p class="text-sm text-gray-500 mt-1"><%= @tokens.count %> token<%= @tokens.count == 1 ? '' : 's' %></p>
  </div>
  <%= link_to "New token", new_api_v1_token_path,
        class: "inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors" %>
</div>

<% if flash[:notice] %>
  <div class="flex items-center gap-3 bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3 mb-6">
    <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
    </svg>
    <%= flash[:notice] %>
  </div>
<% end %>

<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-100 bg-gray-50">
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Expires</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Last used</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @tokens.each do |token| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-6 py-4 font-medium text-gray-900">
            <%= link_to token.name, api_v1_token_path(token), class: "hover:text-indigo-600 transition-colors" %>
          </td>
          <td class="px-6 py-4">
            <% if token.active? %>
              <span class="inline-flex items-center gap-1 rounded-full bg-green-50 px-2.5 py-0.5 text-xs font-medium text-green-700">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                Active
              </span>
            <% else %>
              <span class="inline-flex items-center gap-1 rounded-full bg-red-50 px-2.5 py-0.5 text-xs font-medium text-red-700">
                <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                Expired
              </span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-gray-500">
            <%= token.expires_at.strftime("%b %d, %Y") %>
          </td>
          <td class="px-6 py-4 text-gray-500">
            <%= token.last_used_at ? token.last_used_at.strftime("%b %d, %Y") : "Never" %>
          </td>
          <td class="px-6 py-4">
            <div class="flex items-center justify-end gap-3">
              <%= button_to "Renew", renew_api_v1_token_path(token), method: :patch,
                    class: "text-xs font-medium text-indigo-600 hover:text-indigo-500 transition-colors bg-transparent border-0 cursor-pointer p-0" %>
              <% if token.active? %>
                <%= button_to "Revoke", revoke_api_v1_token_path(token), method: :patch,
                      class: "text-xs font-medium text-amber-600 hover:text-amber-500 transition-colors bg-transparent border-0 cursor-pointer p-0",
                      data: { turbo_confirm: "Revoke \"#{token.name}\"? It will be immediately invalidated." } %>
              <% end %>
              <%= button_to "Delete", api_v1_token_path(token), method: :delete,
                    class: "text-xs font-medium text-red-600 hover:text-red-500 transition-colors bg-transparent border-0 cursor-pointer p-0",
                    data: { turbo_confirm: "Delete \"#{token.name}\"? This cannot be undone." } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
