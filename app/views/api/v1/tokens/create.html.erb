<%#
API Token Creation View
Displays the result of token creation or the creation form.
Used by Api::V1::TokensController#create action.

@param token [ApiToken] The token instance (new or created)
%>
<% content_for :title, "API Tokens — N8N Worker" %>

<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">API Tokens</h1>
    <p class="text-sm text-gray-500 mt-1">Manage programmatic access to the API.</p>
  </div>
  <%= link_to "← Dashboard", dashboard_path, class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" %>
</div>

<% if @token&.persisted? %>
  <!-- Success -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 max-w-xl">
    <div class="flex items-center gap-3 mb-6">
      <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center">
        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-gray-900">Token created successfully</h2>
    </div>

    <dl class="space-y-3 text-sm mb-6">
      <div class="flex justify-between">
        <dt class="text-gray-500">Name</dt>
        <dd class="font-medium text-gray-900"><%= @token.name %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-gray-500">Expires on</dt>
        <dd class="font-medium text-gray-900"><%= @token.expires_at.strftime("%B %d, %Y") %></dd>
      </div>
    </dl>

    <% if @token.respond_to?(:raw_token) %>
      <div class="rounded-lg bg-amber-50 border border-amber-200 p-4">
        <p class="text-xs font-medium text-amber-800 mb-2">
          Copy this token now — it won't be shown again.
        </p>
        <code class="block text-xs font-mono break-all text-amber-900 bg-amber-100 rounded px-3 py-2">
          <%= @token.raw_token %>
        </code>
      </div>
    <% end %>

    <div class="mt-6">
      <%= link_to "Create another token", api_v1_tokens_create_path,
            class: "text-sm font-medium text-indigo-600 hover:text-indigo-500 transition-colors" %>
    </div>
  </div>

<% else %>
  <!-- Form -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 max-w-xl">
    <h2 class="text-lg font-semibold text-gray-900 mb-1">Create new token</h2>
    <p class="text-sm text-gray-500 mb-6">Tokens allow programmatic access to the API.</p>

    <% if @token&.errors&.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 mb-6">
        <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
          <% @token.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with url: api_v1_tokens_path, method: :post do |f| %>
      <div class="space-y-5">
        <div>
          <%= f.label :name, "Token name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :name, value: @token&.name,
                placeholder: "e.g. CI/CD Pipeline",
                required: true,
                class: "w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :expires_at, "Expiration date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <p class="text-xs text-gray-400 mb-1.5">Optional — defaults to 30 days.</p>
          <%= f.date_field :expires_at,
                value: @token&.expires_at&.to_date,
                min: Date.tomorrow,
                class: "w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>

        <%= f.submit "Create token",
              class: "w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors cursor-pointer mt-2" %>
      </div>
    <% end %>
  </div>
<% end %>
