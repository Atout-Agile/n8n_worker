<%# 
API Token Creation View
Displays the result of token creation or the creation form.
Used by Api::V1::TokensController#create action.

@param token [ApiToken] The token instance (new or created)
%>

<div class="api-token-creation">
  <h1>API Token Management</h1>
  
  <% if @token&.persisted? %>
    <div class="token-creation-success">
      <h2>Token Created Successfully</h2>
      
      <div class="token-details">
        <p><strong>Name:</strong> <%= @token.name %></p>
        <p><strong>Expires on:</strong> <%= @token.expires_at.strftime("%B %d, %Y at %I:%M %p") %></p>
        
        <% if @token.respond_to?(:raw_token) %>
          <div class="token-value">
            <p><strong>Token (save this - it won't be shown again):</strong></p>
            <code class="api-token-code"><%= @token.raw_token %></code>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="token-creation-form">
      <h2>Create New API Token</h2>
      <p>API tokens allow you to authenticate with our API programmatically.</p>
    </div>
  <% end %>
</div>
